# Ambiente pronto para producao.
# Preencha apenas os valores abaixo e publique como .env no servidor.

API_PORT=4100
DATA_DIR=server/data-willian-holanda

# Seguranca do painel
JWT_SECRET=COLE_UMA_CHAVE_LONGA_E_ALEATORIA_AQUI
ADMIN_PASSWORD=COLE_UMA_SENHA_FORTE_DO_ADMIN
STAFF_PASSWORD=COLE_UMA_SENHA_FORTE_DA_SECRETARIA

# URL publica do sistema
PUBLIC_BASE_URL=https://sistema.seudominio.com.br

# WhatsApp Cloud API oficial da Meta
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_VERIFY_TOKEN=COLE_UM_TOKEN_DE_VERIFICACAO_SEGURO
WHATSAPP_ACCESS_TOKEN=COLE_O_ACCESS_TOKEN_DA_META
WHATSAPP_PHONE_NUMBER_ID=COLE_O_PHONE_NUMBER_ID
WHATSAPP_APP_SECRET=COLE_O_APP_SECRET_DA_META

# Notificacao do medico
WHATSAPP_DOCTOR_PHONE=55DDDNUMERO_DO_MEDICO
WHATSAPP_DOCTOR_TEMPLATE_NAME=novo_agendamento_resumo
WHATSAPP_DOCTOR_TEMPLATE_LANGUAGE=pt_BR
WHATSAPP_DOCTOR_FALLBACK_TEXT_ENABLED=false

# Lembretes automaticos para pacientes
WHATSAPP_PATIENT_REMINDER_TEMPLATE_NAME=lembrete_agendamento_amanha
WHATSAPP_PATIENT_SAME_DAY_TEMPLATE_NAME=lembrete_agendamento_hoje
WHATSAPP_PATIENT_TEMPLATE_LANGUAGE=pt_BR
WHATSAPP_PATIENT_FALLBACK_TEXT_ENABLED=false
