{
  "name": "willian-holanda-sistema",
  "version": "1.0.0",
  "private": true,
  "homepage": "/admin",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "proxy": "http://localhost:4100",
  "scripts": {
    "server": "node --no-warnings=ExperimentalWarning server/index.js",
    "start": "react-scripts start",
    "build:admin": "react-scripts build",
    "build:lp": "npm --prefix codigo-fonte-lp run build",
    "build": "npm run build:admin && npm run build:lp",
    "check:prod-env": "node scripts/validate-production-env.cjs .env.production.local",
    "check:prod-example": "node scripts/validate-production-env.cjs .env.production.example",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart willian-holanda-sistema",
    "pm2:stop": "pm2 stop willian-holanda-sistema"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "ajv-keywords": "^3.5.2",
    "playwright": "^1.59.1",
    "pm2": "^6.0.8"
  }
}
